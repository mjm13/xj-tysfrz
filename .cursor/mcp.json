{
  "mcpServers": {
    "mysql-readonly": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-mysql"
      ],
      "env": {
        "MYSQL_HOST": "${DB_HOST}",
        "MYSQL_PORT": "${DB_PORT}",
        "MYSQL_DATABASE": "${DB_NAME}",
        "MYSQL_USER": "${DB_USER}",
        "MYSQL_PASSWORD": "${DB_PASSWORD}",
        "MYSQL_SSL": "false",
        "MYSQL_READONLY": "true"
      }
    }
  }
}
